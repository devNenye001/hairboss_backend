PORT=5000
NODE_ENV=development
JWT_SECRET=supersecretjwtkeyforonlyonehairboss123

# Update with your actual PostgreSQL URL (e.g. Supabase, Neon, or local Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hairboss

# Admin Account Auto-Seeding (Logs in on /admin/login)
ADMIN_NAME="Admin Hairboss"
ADMIN_EMAIL=admin@onlyonehairboss.com
ADMIN_PASSWORD=AdminPass123!

# Google Auth Client ID and Secret (Fill to use Google Auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# SMTP details (Optional, falls back to logging emails to console if empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="OnlyOne Hairboss" <noreply@onlyonehairboss.com>

# Frontend URL
FRONTEND_URL=http://localhost:5173
