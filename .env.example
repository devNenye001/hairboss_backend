# Server Config
PORT=5000
NODE_ENV=development
JWT_SECRET=some-long-random-string-used-to-sign-jwts

# Database Connection (PostgreSQL)
# e.g., postgresql://username:password@localhost:5432/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hairboss

# Admin Account Auto-Seeding
ADMIN_NAME=Admin Hairboss
ADMIN_EMAIL=admin@onlyonehairboss.com
ADMIN_PASSWORD=AdminPass123!

# Email Configuration
# Production default is Resend over HTTPS. This avoids SMTP connection timeouts on Render.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="OnlyOne Hairboss" <orders@onlyonehairboss.com>
EMAIL_REPLY_TO=onlyonehairboss@gmail.com
EMAIL_LOGO_URL=https://onlyonehairboss.vercel.app/logo1.svg
ORDER_ALERT_EMAIL=onlyonehairboss@gmail.com
EMAIL_TIMEOUT_MS=10000
EMAIL_MAX_ATTEMPTS=3
EMAIL_RETRY_BASE_MS=3000

# SMTP fallback only. Use EMAIL_PROVIDER=smtp only after verifying host, port, auth, and Render connectivity.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_gmail_app_password

# Google OAuth API Credentials (For Google Auth Sign In)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Frontend Origin URL (For redirects)
FRONTEND_URL=http://localhost:5173
